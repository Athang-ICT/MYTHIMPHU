<script>
    (function() {
        function updateCount() {
            var visible = $('.news-card-item:visible').length;
            var total = $('.news-card-item').length;
            $('#news-count').text(visible + ' of ' + total + ' items');
            $('#no-results').toggle(visible === 0);
        }
        $('#news-search').on('keyup', function() {
            var q = $(this).val().toLowerCase();
            $('.news-card-item').each(function(){
                var name = $(this).data('name');
                var desc = $(this).data('desc');
                var match = !q || name.indexOf(q) > -1 || desc.indexOf(q) > -1;
                $(this).toggle(match);
            });
            updateCount();
        });
        // Toggle between sections
        $('#home-link').on('click', function(e) {
            e.preventDefault();
            $('#news-section').show();
            $('#contact-section').hide();
            $('.portal-search-section').show();
            $('#news-search').trigger('keyup'); // Re-apply search
            // Close the menu
            $('#portal-navbar').collapse('hide');
        });
        $('#contact-link').on('click', function(e) {
            e.preventDefault();
            $('#news-section').hide();
            $('#cinema-section').hide();
            $('#contact-section').show();
            $('.portal-search-section').hide();
            $('#no-results').hide();
            // Close the menu
            $('#portal-navbar').collapse('hide');
            // Scroll to top smoothly, accounting for navbar height
            $('html, body').animate({scrollTop: 70}, 300);
        });

        // Contact form submission
        $('#contact-form').on('submit', function(e) {
            e.preventDefault();
            
            var formData = {
                name: $('#contact-name').val(),
                email: $('#contact-email').val(),
                phone: $('#contact-phone').val(),
                subject: $('#contact-subject').val(),
                message: $('#contact-message').val()
            };
            
            // Show loading state
            var $btn = $(this).find('button[type="submit"]');
            var originalText = $btn.html();
            $btn.html('<i class="fa fa-spinner fa-spin"></i> Sending...').prop('disabled', true);
            
            // Simulate form submission (replace with actual AJAX call)
            setTimeout(function() {
                $('#contact-alert')
                    .removeClass('alert-danger')
                    .addClass('alert-success')
                    .html('<i class="fa fa-check-circle"></i> <strong>Success!</strong> Your message has been sent. We\'ll get back to you soon.')
                    .slideDown();
                
                $('#contact-form')[0].reset();
                $btn.html(originalText).prop('disabled', false);
                
                // Hide alert after 5 seconds
                setTimeout(function() {
                    $('#contact-alert').slideUp();
                }, 5000);
            }, 1500);
        });

        updateCount();
    })();
</script>
