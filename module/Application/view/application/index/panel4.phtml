$this->headTitle($title);

// Define news topics
$newsItems = [
    "Kuensel",
    "The Bhutanese"
];
?>

<div class="page-header">
    <h1>News</h1>
</div>

<div class="news-box">

    <h3>Latest News</h3>
    <p class="news-description">
        Stay updated with your favorite news sources. Subscribe to receive notifications.
    </p>

    <ul class="news-list">
        <?php foreach ($newsItems as $item): ?>
            <li>
                <span class="bullet"></span>
                <?= htmlspecialchars($item) ?>
                <button class="subscribe-btn" data-item="<?= urlencode($item) ?>">
                    Subscribe
                </button>
